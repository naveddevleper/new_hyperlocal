# ============================================================
# SHOPIFY HYPERLOCAL NOTIFIER — ENVIRONMENT CONFIGURATION
# Copy this file to ".env" and fill in your real values.
# This is the ONLY file you should need to edit.
# ============================================================

# ---- 1. Shopify credentials (from your custom app) ----
# Get these from: Shopify Admin -> Settings -> Apps and sales channels
# -> Develop apps -> Build apps in Dev Dashboard (see README for details)
SHOPIFY_API_KEY=a2ea95aa8f67644b40055af0fa5ece5e
SHOPIFY_API_SECRET=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
SHOPIFY_ACCESS_TOKEN=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

# ---- 2. Your store domain (no https://, no trailing slash) ----
SHOPIFY_SHOP_DOMAIN=thrillerrr.myshopify.com

# Admin API version (default is fine, only change if you know why)
SHOPIFY_API_VERSION=2026-04

# ---- 3. Hyperlocal tag matching ----
# Comma separated list of order tags that count as "hyperlocal".
# Matching is case-insensitive and ignores extra spaces.
HYPERLOCAL_TAGS=hyperlocal,HyperLocal,local-delivery

# ---- 4. App / webhook settings ----
PORT=3000

# Public HTTPS URL where THIS app is reachable from the internet.
# Local testing: run "ngrok http 3000" and paste the https URL it gives you.
# Production: use your server/hosting domain, e.g. https://notifier.yourdomain.com
APP_BASE_URL=lightcyan-koala-466926.hostingersite.com

# Which Shopify event triggers the check (rarely needs changing)
WEBHOOK_TOPIC=orders/create

# If true, the app registers its own webhook with Shopify every time it starts.
# Safe to leave as true — it will not create duplicate webhooks.
AUTO_REGISTER_WEBHOOK=true

# ---- 5. Email (SMTP) settings ----
# Example values below are for Gmail (use a 16-character App Password,
# not your normal Gmail password). Any SMTP provider works (Outlook,
# Zoho, SendGrid SMTP, Amazon SES SMTP, your hosting provider, etc.)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=hemant.bhalla@soulsyncwellness.in
SMTP_PASS=Rb7&n9^l

# Who the notification email appears to be from / sent to.
# NOTIFY_EMAIL_TO can be a comma separated list of multiple recipients.
NOTIFY_EMAIL_FROM=hemant.bhalla@soulsyncwellness.in
NOTIFY_EMAIL_TO=navedahamad2016@gmail.com
